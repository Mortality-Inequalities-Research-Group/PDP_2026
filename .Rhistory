pacman::p_load(here, tidyverse, HMDHFDplus, remotes, vital, dplyr, rstan, plotly)
zusername_f <- "anfesanz@gmail.com"
zpassword_f <- "cyknU0-pywzin-xyfmif"
#HMDB - Data
swe_vital <- read_hmd(
country = "SWE",
username = zusername_f,
password = zpassword_f,
variables = c("Mx", "Deaths", "Exposures") # Download rates, deaths, and exposure
)
# Define year range
year_init <- 1946
year_end  <- 2009
#Prepare data for the analysis (years of interest, sex)
data_lc <- swe_vital %>%
as_tibble() %>%
filter(Year %in% year_init:year_end, Sex == "Female") %>%
mutate(
Age = cut(
Age,
breaks = c(0, 1, seq(5, 100, by = 5), Inf),
labels = c(0, 1, seq(5, 95, by = 5), 100),
right = FALSE,        # intervals [a, b)
include.lowest = TRUE # include age 0 in the first interval
),
) %>%
group_by(Year, Sex, Age) %>%
summarise(
Deaths = sum(Deaths, na.rm = TRUE),
Exposures = sum(Exposures, na.rm = TRUE),
.groups = "drop"
) %>%
mutate(
Mortality = Deaths / Exposures,
lmx = log(Mortality),
OpenInterval = (Age == 100)  # Only age 100 is open interval now
)
#Prepare data for Stan (Lee-Carter Model)
data.inp <- list(
d = data_lc %>%
select(Year, Age, lmx) %>%
pivot_wider(names_from = Year, values_from = lmx) %>%
arrange(Age) %>%
select(-Age) %>%
as.matrix(),
N = length(unique(data_lc$Age[data_lc$Sex == "Female"])),   # number of age groups
T = length(year_init:year_end),                               # number of years
F = 10                                                        # forecast horizon (example)
)
inits <- list(A=rep(-1,data.inp$N),
k=-(2:data.inp$T),
sig=c(1,1))
#Model Estimation
fit.blc = stan(file = "src/model_LC.stan",
data = data.inp,
iter = 1500,
warmup = 1000,
thin=1,
verbose = FALSE,
control = list(adapt_delta=0.97,max_treedepth=12),
init = list(inits,inits),
chains=2, cores = 2,
seed=26)
#Diagnostics
#Visual and numerical checking of convergence
#pdf(file = "/Users/felipesanchez/Dropbox/TransferFiles/UoM/2Semester/Demography Forecasting/Lab7/images/sweden/1.traceconvergence.pdf",  width = 4,  height = 4)
plot(fit.blc, plotfun = "trace", pars = c("sig"), inc_warmup = F)
plot(fit.blc, plotfun = "trace", pars = c("A"), inc_warmup = F)
plot(fit.blc,  plotfun = "rhat", pars = c("mdf","k","kf","A","B","sig","phi"))
plot(fit.blc, plotfun = "trace", pars = c("ben"), inc_warmup = F)
plot(fit.blc, plotfun = "trace", pars = c("B"), inc_warmup = F)
#Effective sample size
plot(fit.blc,  plotfun = "ess", pars = c("mdf","k","kf","A","B","sig","phi"))
#Checking the posterior distribution
sum.blc = summary(fit.blc)$summary
plot(fit.blc, plotfun = "plot", pars = c("A"), inc_warmup = F) +
labs(title="Average age profile")
plot(fit.blc, plotfun = "plot", pars = c("B"), inc_warmup = F) +
labs(title="Changes of age profile")
plot(fit.blc, plotfun = "plot", pars = c("k","kf"), inc_warmup = F) +
labs(title="Time effect")
reported_data = filter(data_lc, Year>1945) %>%
mutate(Age =as.character(Age))  %>%
group_by(Year) %>%
mutate(ax = case_when(
Age=="0" ~ 0.053 + 2.8*Mortality,
Age=="1" ~ 1.522-1.518*Mortality,
Age=="100" ~ 1/Mortality,
TRUE ~ 2.5),
n = case_when(
Age=="0" ~ 1,
Age=="1" ~ 4,
Age=="100" ~ 30,
TRUE ~ 5),
lx = lag(cumprod((1-ax*Mortality)/(1+(n-ax)*Mortality)), default=1),
Lx = n * lead(lx, default = 0) + (ax*(lx - lead(lx, default = 0))),
Lx = ifelse(Age=="100",lx/Mortality,Lx),
ex1 = ifelse(Age=="0",rev(cumsum(rev(Lx))) / lx,0)
) %>%
ungroup()
#Calculating and forecasting life expectancy from Lee-Carter model
##################################################################
lt_SE = fit.blc %>%
as.data.frame() %>%
select(matches("mdf")) %>%
pivot_longer(cols=everything(),
names_to="Parameter",
values_to="Value") %>%
group_by(Parameter) %>%
mutate(Iteration=row_number(Parameter)) %>%
ungroup() %>%
#some renaming going on here with string function str_match
separate(col = Parameter,
into = c("Age","Year"),
sep=",") %>%
mutate(Age=str_match(Age,"\\d+") %>% as_factor() %>% recode(!!!setNames(levels(data_lc$Age),1:22)),
Year = 1945+as.integer(str_match(Year,"\\d+")),
Mortality=exp(Value)) %>%
filter(Iteration%in%seq(2,1000,2)) %>%
# and calculating the life table
group_by(Year,Iteration) %>%
mutate(ax = case_when(
Age=="0" ~ 0.053 + 2.8*Mortality,
Age=="1" ~ 1.522-1.518*Mortality,
Age=="100" ~ 1/Mortality,
TRUE ~ 2.5),
n = case_when(
Age=="0" ~ 1,
Age=="1" ~ 4,
Age=="100" ~ 30,
TRUE ~ 5),
lx = lag(cumprod((1-ax*Mortality)/(1+(n-ax)*Mortality)), default=1),
Lx = n * lead(lx, default = 0) + (ax*(lx - lead(lx, default = 0))),
Lx = ifelse(Age=="100",lx/Mortality,Lx),
ex2 = ifelse(Age=="0",rev(cumsum(rev(Lx))) / lx,0)
) %>%
ungroup() %>%
group_by(Age,Year) %>%
summarise(q10=quantile(ex2,0.1),q50=quantile(ex2,.5),q90=quantile(ex2,.9)) %>%
ungroup()
#Joining reported and estimated life expectancy
###############################################
data_age0 = left_join(lt_SE, reported_data)
#Plotting observed and forecast life expectancy
library("ggplot2")
ggplot(filter(data_age0, Age=="0")) +
geom_line(aes(x=Year,y=q50, colour="Median"), size=1.05) +
geom_line(aes(x=Year,y=ex1, colour="Reported"), size=1.2) +
geom_ribbon(aes(x=Year,ymin=q10,ymax=q90, fill="80% CI"),alpha=0.3) +
geom_vline(xintercept = 2009, linetype="dashed", colour="black") +
scale_x_continuous(expand = c(0,0)) +
scale_color_manual("", values = c("red","black")) +
scale_fill_manual("",values="red") +
labs(y="Age")
ggplot(filter(data_age0, Age == "0")) +
geom_line(aes(x = Year, y = q50, colour = "Median"), linewidth = 1.05) +
geom_line(aes(x = Year, y = ex1, colour = "Reported"), linewidth = 1.2) +
geom_ribbon(aes(x = Year, ymin = q10, ymax = q90, fill = "80% CI"), alpha = 0.3) +
geom_vline(xintercept = 2009, linetype = "dashed", colour = "black") +
scale_x_continuous(expand = c(0,0)) +
scale_color_manual("", values = c("Median" = "red", "Reported" = "black")) +
scale_fill_manual("", values = "red") +
labs(y = "Life expectancy at birth")
ggplot(filter(data_age0, Age=="0")) +
geom_line(aes(x=Year,y=q50, colour="Median"), size=1.05) +
geom_line(aes(x=Year,y=ex1, colour="Reported"), size=1.2) +
geom_ribbon(aes(x=Year,ymin=q10,ymax=q90, fill="80% CI"),alpha=0.3) +
geom_vline(xintercept = 2009, linetype="dashed", colour="black") +
scale_x_continuous(expand = c(0,0)) +
scale_color_manual("", values = c("red","black")) +
scale_fill_manual("",values="red") +
labs(y="Age")
