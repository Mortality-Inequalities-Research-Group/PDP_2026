set.seed(202)
girl <- rbinom(n = 1000, size = 1, prob = 0.4854369)
a <- 5; b <- 5
th <- seq(0, 1, by = 0.001)
k <- sum(girl[1:20])        # sample size: 20
n <- length(girl[1:20])
plot(th, dbeta(th, a, b), ylim = c(0,5), col = "darkgrey", type = "l")   # Beta(5,5) prior
lines(th, dbeta(th, k+1, n-k+1), col = "red")                             # likelihood (scaled)
lines(th, dbeta(th, a+k, b+n-k), col = "black", lwd = 3)                  # posterior
plot(th, dbeta(th, 0.5, 0.5), ylim = c(0,30), col = "darkgrey", type = "l")   # Beta(0.5,0.5)
plot(th, dbeta(th, 1000, 1000*(1-0.4854369)/0.4854369), ylim = c(0,400), col = "darkgrey", type = "l")
