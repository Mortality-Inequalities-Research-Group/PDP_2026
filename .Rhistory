# --- 1. Fix column names (case + duplicates) ---
names(df) <- toupper(names(df))
df <- df[!duplicated(names(df))]
# --- 2. Clean encoding (critical for DuckDB) ---
df <- clean_utf8(df)
# --- 3. Add state identifier ---
df$UF <- uf
if (first) {
# First state: create table (overwrite if it somehow exists)
dbWriteTable(con, "mortality", df, overwrite = TRUE)
first <- FALSE
message("Table created with columns: ", paste(names(df), collapse = ", "))
} else {
# Subsequent states: align columns and append
table_cols <- dbListFields(con, "mortality")
# Add any new columns from this state to the table
new_cols <- setdiff(names(df), table_cols)
for (col in new_cols) {
query <- sprintf("ALTER TABLE mortality ADD COLUMN %s VARCHAR", col)
dbExecute(con, query)
message("  Added column: ", col)
}
# Refresh table columns after ALTER
table_cols <- dbListFields(con, "mortality")
# Add missing columns to the data frame (with NA)
missing_in_df <- setdiff(table_cols, names(df))
df[missing_in_df] <- NA
# Reorder columns to match table order
df <- df[, table_cols, drop = FALSE]
# Append
dbAppendTable(con, "mortality", df)
}
rm(df)
gc()
message("Finished ", uf, "\n")
}
