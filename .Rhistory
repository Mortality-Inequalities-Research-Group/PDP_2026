"RS", "RO", "RR", "SC", "SP", "SE", "TO")
# ----------------------------------------------------------------------
# Helper: clean UTF-8 encoding for all character columns
# ----------------------------------------------------------------------
clean_utf8 <- function(df) {
# Convert factors to character
df[] <- lapply(df, function(x) {
if (is.factor(x)) as.character(x) else x
})
# Convert all character columns to valid UTF-8, dropping invalid bytes
char_cols <- sapply(df, is.character)
df[char_cols] <- lapply(df[char_cols], function(x) {
iconv(x, to = "UTF-8", sub = "")  # replace invalid bytes with empty string
})
# Optional: convert empty strings to NA (if preferred)
# df[char_cols] <- lapply(df[char_cols], function(x) ifelse(x == "", NA, x))
df
}
